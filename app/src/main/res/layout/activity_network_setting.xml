<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:uilib="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/xm_root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/new_bg_color"
    android:orientation="vertical">


    <include
        android:id="@+id/layoutTop"
        layout="@layout/include_title_layout"
        uilib:RightText="finish"
        uilib:TitleText="Network_setting" />

    <LinearLayout
        style="@style/ThemeLayoutStyle"
        android:id="@+id/ll_network_mode_select"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:orientation="vertical">

        <CheckBox
            android:id="@+id/ap_setting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:button="@null"
            android:gravity="center_vertical"
            android:minHeight="@dimen/item_min_height"
            android:textSize="16sp"
            android:drawableRight="@drawable/feedback_selected"
            android:drawableEnd="@drawable/feedback_selected"
            android:textStyle="bold"
            android:text="Ap_model"
            android:textColor="@color/color_text_normal" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#F1F1F1" />

        <CheckBox
            android:id="@+id/router_setting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:button="@null"
            android:gravity="center_vertical"
            android:minHeight="@dimen/item_min_height"
            android:textSize="16sp"
            android:drawableEnd="@drawable/feedback_selected"
            android:textStyle="bold"
            android:text="Router_model"
            android:textColor="@color/color_text_normal" />
    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="15dp">

        <TextView
            android:id="@+id/AP_model_tip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="25dp"
            android:paddingRight="25dp"
            android:paddingStart="25dp"
            android:paddingEnd="25dp"
            android:gravity="center"
            android:text="AP_model_Back_tip"
            android:visibility="gone"
            android:layout_centerInParent="true"/>

        <LinearLayout
            android:id="@+id/router_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:orientation="vertical">

            <LinearLayout
                style="@style/ThemeLayoutStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/item_min_height"
                    android:layout_gravity="center_vertical"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/wifi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawablePadding="@dimen/normal_padding"
                        android:gravity="center_vertical"
                        android:hint="Select_wifi"
                        android:text=""
                        android:textStyle="bold"
                        android:textColorHint="@color/color_text_normal"
                        android:textColor="@color/color_text_normal"
                        android:textSize="16sp" />

                    <ImageView
                        android:id="@+id/wifi_drop"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_alignParentEnd="true"
                        android:background="@drawable/wifi_drop"
                        android:visibility="gone"/>
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/line_color" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/item_min_height"
                    android:layout_gravity="center_vertical"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/wifi_psd"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:drawablePadding="@dimen/normal_padding"
                        android:hint="password"
                        android:gravity="start"
                        android:textAlignment="viewStart"
                        android:inputType="textPassword"
                        android:maxLength="32"
                        android:textColor="@color/color_text_normal"
                        android:textSize="16sp"
                        android:textColorHint="@color/color_text_normal"/>

                    <com.xm.ui.widget.ButtonCheck
                        android:id="@+id/psd_show"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_marginEnd="0dp"
                        android:visibility="visible"
                        tools:visibility="visible"
                        android:paddingEnd="10dp"
                        uilib:NormalBkg="@drawable/login_close_eye"
                        uilib:SelectedBkg="@drawable/login_open" />
                </RelativeLayout>
            </LinearLayout>

            <com.xm.ui.widget.ItemSetLayout
                android:id="@+id/il_wifi_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:textColor="@color/color_text_light1"
                android:textSize="14sp"
                android:textStyle="bold"
                uilib:show_left_line="false"
                uilib:left_title_text="Wifi_list"
                uilib:contentPaddingStart="0dp"
                uilib:contentPaddingEnd="0dp"
                uilib:contentPaddingTop="@dimen/half_of_normal_padding"
                uilib:contentPaddingBottom="5dp"
                uilib:main_layout="@layout/layout_network_wifi_list"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_margin="5dp"
                android:ellipsize="marquee"
                android:gravity="center"
                android:marqueeRepeatLimit="marquee_forever"
                android:text="AP_config_NetWork_tip"
                android:textColor="@android:color/holo_red_light"
                android:textSize="@dimen/to_small_text_size" />
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
